# Pi config — safe to share publicly
# Keep: settings, modes, keybindings, custom extensions, model definitions
# Ignore: secrets, local caches, private history, and session data

# Secrets / authentication
auth.json
*.key
*.token
*.secret
.env
.env.*

# Local trust / filesystem paths
trust.json

# Runtime history / session data (private by default)
run-history.jsonl
sessions/

# MCP caches (regenerated locally)
mcp-cache.json
mcp-npx-cache.json
mcp-onboarding.json

# MCP OAuth tokens (generated by pi-mcp-adapter)
mcp-oauth/

# Generated by pi-subagents when ejecting/creating agents.
# Custom agents you author may be worth sharing; remove this if you want them tracked.
agents/

# Pi-magics plans/specs (generated per-project / per-task)
pi-magics/

# Dependency install directory
npm/node_modules/

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
